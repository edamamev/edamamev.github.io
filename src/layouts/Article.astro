---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { frontmatter, url } = Astro.props;
const { title, pubDate, description, author, tags } = frontmatter;
const formattedDate = new Date(pubDate).toISOString().slice(0, 10);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body>
  <Header />
  <main>
    <article class="h-entry">
      <h1 class="p-name">{title}</h1>

      <p>
        <time class="dt-published" datetime={formattedDate}>{formattedDate}</time>
        <span class="sep"> | </span>
        <span
            set:html={
              tags.map(tag =>
            `<a class="p-category" href="/tags/${encodeURIComponent(tag)}">${tag}</a>`).join(", ")
            }
        />
      </p>

      <p class="p-summary">{description}</p>
      <hr>
      <div class="e-content">
        <slot />
      </div>

      <p class="p-author h-card">
        <a href="/" class="u-url">{author}</a>
      </p>
    </article>
  </main>
  <Footer />
</body>
</html>
