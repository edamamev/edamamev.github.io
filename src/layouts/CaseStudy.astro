---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { frontmatter } = Astro.props;
const { title, date, description, skills, status } = frontmatter;
const formattedDate = date ? new Date(date).toISOString().slice(0, 10) : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Portfolio</title>
</head>
<body>
  <Header />
  <main>
    <article class="case-study-detail">
      <p class="back-link">
        <a href="/portfolio/">&larr; Back to portfolio</a>
      </p>

      <h1>{title}</h1>

      <p class="case-meta">
        {formattedDate && <time datetime={formattedDate}>{formattedDate}</time>}
        {status && (
          <span class={`case-status status-${status.toLowerCase()}`}>{status}</span>
        )}
      </p>

      {
        description && <p class="case-summary">{description}</p>
      }

      {
        skills && skills.length > 0 && (
          <p class="case-skills">
            <strong>ASD Skills:</strong> {skills.join(" · ")}
          </p>
        )
      }

      <hr />

      <div class="case-content">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
  .case-study-detail {
    max-width: 550px;
    margin: auto;
  }

  .back-link {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .back-link a {
    color: var(--accent);
  }

  h1 {
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .case-meta {
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 0.75rem;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .case-status {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .status-complete {
    background: #1a3a1a;
    color: #7ec77e;
  }

  .status-in-progress {
    background: #3a2a0a;
    color: #d4a84b;
  }

  .status-planned {
    background: #1a1a1a;
    color: #666;
  }

  .case-summary {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .case-skills {
    font-size: 0.85rem;
    color: #999;
    margin-bottom: 0.5rem;
  }

  .case-content {
    line-height: 1.6;
    color: var(--text);
  }

  hr {
    border: none;
    border-top: 1px solid var(--primary);
    margin: 1.5rem 0;
  }
</style>
