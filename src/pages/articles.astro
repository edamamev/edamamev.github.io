---
import Base from "../layouts/Base.astro";
import ListItem from "../components/ListItem.astro";
const allPosts = Object.values(import.meta.glob('./articles/*.md', { eager: true }))
  .sort((a : any, b : any) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
const pageTitle = "Articles"
---
<Base pageTitle={pageTitle}>
  <div slot="below-title">Lorem Ipsum</div>
    <ul class="post-list" slot="below-break">
      {allPosts.map((article : any) =>
        <ListItem
          title={article.frontmatter.title}
          description={article.frontmatter.description}
          pubDate={article.frontmatter.pubDate}
          tags={article.frontmatter.tags}
          url={article.url}
        />
      )}
    </ul>
  </div>
</Base>
